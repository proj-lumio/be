# ── App ──
APP_ENV=development
APP_DEBUG=true

# ── MongoDB Atlas ──
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/?appName=Lumio
MONGODB_DB_NAME=lumio

# ── Qdrant Cloud ──
QDRANT_URL=https://xxxxx.cloud.qdrant.io
QDRANT_API_KEY=your-key
QDRANT_COLLECTION=lumio_documents

# ── Neo4j AuraDB ──
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# ── Regolo AI ──
REGOLO_API_KEY=sk-xxxxx
REGOLO_BASE_URL=https://api.regolo.ai/v1
REGOLO_MODEL=gpt-oss-120b

# ── JWT Auth ──
JWT_SECRET_KEY=change-me-generate-a-random-256bit-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── Backoffice ──
BO_EMAIL=admin@lumio.local
BO_PASSWORD=change-me

# ── Dev mode ──
DEV_AUTH_BYPASS=true
